  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },

    { "key": "adminEmail", "value": "admin@duoc.cl" },
    { "key": "adminPassword", "value": "admin123" },
    { "key": "supervisorEmail", "value": "supervisor@duoc.cl" },
    { "key": "supervisorPassword", "value": "supervisor123" },
    { "key": "workerEmail", "value": "trabajador@duoc.cl" },
    { "key": "workerPassword", "value": "trabajador123" },

    { "key": "userId", "value": "1" },
    { "key": "roleId", "value": "1" },
    { "key": "statusId", "value": "1" },
    { "key": "apartmentId", "value": "1" },
    { "key": "taskId", "value": "1" }
